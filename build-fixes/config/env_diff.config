# CONFIG_TARGET_ALL_PROFILES is not set
CONFIG_TARGET_OPTIONS=y
CONFIG_EXTRA_OPTIMIZATION="-fno-caller-saves -fno-plt -fipa-pta -fno-signed-zeros -ftree-vectorize -ftree-vectorizer-verbose=2 -fopt-info-vec"
#__CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -mcpu=cortex-a57+crypto+fp+crc+simd -mtune=cortex-a57"
#__CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -mcpu=cortex-a15+neon-vfpv4 -mtune=cortex-a15"
CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -mcpu=cortex-a15 -mfpu=neon-vfpv4 -mtune=cortex-a15 -mfloat-abi=hard -mthumb -mvectorize-with-neon-quad -mtls-dialect=gnu2 -Wa,-mimplicit-it=always"

# CONFIG_GCC_USE_DEFAULT_VERSION is not set
CONFIG_TOOLCHAINOPTS=y

CONFIG_GCC_USE_VERSION_13=y
CONFIG_GCC_VERSION="13.3.0"
CONFIG_GCC_VERSION_13=y

#__CONFIG_GCC_USE_VERSION_14=y
#__CONFIG_GCC_VERSION="14.2.0"
#__CONFIG_GCC_VERSION_14=y

# -mvectorize-with-neon-quad -mfpu=neon-fp-armv8 -mneon-for-64bits
#__CONFIG_DEFAULT_TARGET_OPTIMIZATION="-O3 -pipe -mcpu=cortex-a57+crypto+fp+crc+simd -mtune=cortex-a57"
#__CONFIG_DEFAULT_TARGET_OPTIMIZATION="-O3 -pipe -mcpu=cortex-a15+neon-vfpv4 -mtune=cortex-a15"
CONFIG_DEFAULT_TARGET_OPTIMIZATION="-O3 -pipe -mcpu=cortex-a15 -mfpu=neon-vfpv4 -mtune=cortex-a15 -mfloat-abi=hard -mthumb -mvectorize-with-neon-quad -mtls-dialect=gnu2 -Wa,-mimplicit-it=always"
#__CONFIG_SOFT_FLOAT is not set

CONFIG_TARGET_SUFFIX="muslgnueabihf"

#__CONFIG_CPU_TYPE="cortex-a57+neon-vfpv4"
CONFIG_CPU_TYPE="cortex-a15+neon-vfpv4"

#--with-mode=thumb
#__CONFIG_EXTRA_GCC_CONFIG_OPTIONS="--with-cpu=cortex-a57 --with-cpu-64=cortex-a57 --with-tune=cortex-a57 --with-tune-64=cortex-a57"
CONFIG_EXTRA_GCC_CONFIG_OPTIONS="--with-cpu=cortex-a15 --with-fpu=neon-vfpv4 --with-float=hard"

#__CONFIG_EXTERNAL_KERNEL_TREE=""
#__CONFIG_KERNEL_GIT_CLONE_URI="git@github.com:google/bbr.git"
#__CONFIG_KERNEL_GIT_LOCAL_REPOSITORY="/home/maks/bbr"
#__CONFIG_KERNEL_GIT_REF="90210de4b779d40496dee0b89081780eeddf2a60"
#__CONFIG_KERNEL_GIT_MIRROR_HASH="90210de4b779d40496dee0b89081780eeddf2a60"
#__CONFIG_TESTING_KERNEL=y


#__CONFIG_KERNEL_TRANSPARENT_HUGEPAGE=y
#__CONFIG_KERNEL_TRANSPARENT_HUGEPAGE_MADVISE=y
#__CONFIG_KERNEL_TRANSPARENT_HUGEPAGE_ALWAYS is not set


CONFIG_STRIP_KERNEL_EXPORTS=y
#__CONFIG_USE_MKLIBS is not set



