# https://wiki.archlinux.org/title/Domain_name_resolution#DNS_servers

CONFIG_PACKAGE_adguardhome=m

# CONFIG_PACKAGE_luci-app-nextdns is not set

# CONFIG_PACKAGE_luci-app-smartdns is not set

# CONFIG_PACKAGE_knot is not set
# CONFIG_PACKAGE_knot-nsupdate is not set
# CONFIG_PACKAGE_knot-resolver is not set
# CONFIG_PACKAGE_knot-resolver_dnstap is not set

# CONFIG_PACKAGE_pdns is not set
# CONFIG_PACKAGE_pdns-recursor is not set
# CONFIG_PACKAGE_pdns-backend-geoip is not set

CONFIG_PACKAGE_dnsproxy=m

CONFIG_PACKAGE_iperf3=m

CONFIG_PACKAGE_openssl-util=m
CONFIG_PACKAGE_libwolfssl-benchmark=m

CONFIG_PACKAGE_hwclock=m
CONFIG_PACKAGE_hwinfo=m

CONFIG_luci-app-olsr=m

CONFIG_PACKAGE_coremark=m
CONFIG_COREMARK_ENABLE_MULTITHREADING=y
CONFIG_COREMARK_NUMBER_OF_THREADS=4
CONFIG_COREMARK_THREADS_NUMBER=4
CONFIG_COREMARK_DATA_SIZE=5000
