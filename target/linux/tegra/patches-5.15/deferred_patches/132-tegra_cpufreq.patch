+		if (ktime_ms_delta(now, td->one_shot_invalid_time_start) >
+		    td->one_shot_invalid_time * 1000L) {
+			td->one_shot_invalid_time_start = now;
+			dfll_invalidate_one_shot(td);
+		}
+	}
+	spin_unlock_irqrestore(&td->lock, flags);
