+#define DFLL_CALIBRATE_FLOOR_RETRY	10
+
+static bool dfll_one_shot_log_time(struct tegra_dfll *td)
+{
+	ktime_t start, end;
+	bool ret;
+
+	start = ktime_get();
+	ret = dfll_one_shot_calibrate_floors(td);
+	end = ktime_get();
+
+	pr_debug("%s: time_us: %lld\n", __func__, ktime_us_delta(end, start));
+	return ret;
+}
