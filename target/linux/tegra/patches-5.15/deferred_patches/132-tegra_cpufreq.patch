+			dev_info(td->dev, "entered closed loop mode\n");
+		}
+		break;
+
+	case ABORT_PARENT_CHANGE:
+		/* fall thru to re-lock DFLL if switch to PLL was aborted */
+
+	case POST_PARENT_CHANGE:
+		if (cclk_g_parent == td->dfll_clk) {
