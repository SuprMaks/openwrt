+	struct tegra_dfll *td = dev_get_drvdata(dev);
+	unsigned long flags;
+
+	spin_lock_irqsave(&td->lock, flags);
+
+	if ((td->tune_range > DFLL_TUNE_LOW) &&
+	    (td->tune_range < DFLL_TUNE_HIGH)) {
+		hrtimer_start(&td->tune_timer, td->tune_delay,
